{
  "name": "@gradientedge/commercetools-utils",
  "version": "0.0.0-development",
  "description": "Provide utility classes and functions for interacting with the commercetools API",
  "main": "./dist/cjs/index.js",
  "module": "./dist/mjs/index.js",
  "types": "./dist/mjs/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/mjs/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/mjs/index.d.ts"
    }
  },
  "scripts": {
    "cz": "cz",
    "clean": "rimraf dist",
    "watch": "tsc --watch",
    "lint": "eslint './src/**/*.ts' --max-warnings=0",
    "generate-types": "node ./generate-type-exports.mjs",
    "package": "pnpm clean && pnpm build",
    "prepare": "husky install",
    "prettier": "prettier --check \"**/*.{ts,js,json,graphql}\"",
    "prettify": "prettier --write \"**/*.{ts,js,json,graphql}\"",
    "validate": "npm run prettier && npm run lint && pnpm build && npm run test",
    "docs": "typedoc --readme ./README.md",
    "semantic-release": "semantic-release",
    "build": "tsc --build && pnpm build:commonjs",
    "build:commonjs": "tsc --build tsconfig-cjs.json",
    "build:watch": "tsc --build --incremental --watch",
    "test": "TZ=UTC vitest run",
    "test:coverage": "TZ=UTC vitest run --coverage",
    "prepack": "echo '{\"type\": \"commonjs\"}' > dist/cjs/package.json",
    "postpack": "rm -f dist/cjs/package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gradientedge/commercetools-utils.git"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "commercetools",
    "utils"
  ],
  "author": "Gradient Edge Ltd.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gradientedge/commercetools-utils/issues"
  },
  "homepage": "https://github.com/gradientedge/commercetools-utils#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@sinonjs/fake-timers": "11.3.1",
    "@types/json-stringify-safe": "5.0.3",
    "@types/lodash": "4.17.23",
    "@types/lodash.clonedeep": "4.5.9",
    "@types/node": "24.1.0",
    "@types/qs": "6.15.0",
    "@types/sinonjs__fake-timers": "8.1.5",
    "@types/traverse": "0.6.37",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vitest/coverage-v8": "4.1.5",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "^17.5.0",
    "husky": "9.1.7",
    "nock": "14.0.6",
    "prettier": "3.6.2",
    "rimraf": "6.1.3",
    "semantic-release": "24.2.7",
    "ts-node": "^10.9.2",
    "typedoc": "0.28.19",
    "typescript": "5.8.3",
    "vite": "^8.0.10",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@tshttp/status": "2.0.0",
    "axios": "1.15.0",
    "json-stringify-safe": "5.0.1",
    "qs": "6.15.0",
    "traverse": "0.6.11",
    "uuid": "14.0.0"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": "4.17.23",
      "lodash": "4.17.23",
      "js-yaml": "3.14.2",
      "markdown-it": "14.1.1",
      "tmp": "0.2.5",
      "diff": "5.2.2",
      "flatted": ">=3.4.2",
      "handlebars": ">=4.7.9",
      "brace-expansion@^1.0.0": ">=1.1.13 <2.0.0",
      "brace-expansion@^2.0.0": ">=2.0.3 <3.0.0",
      "brace-expansion@^5.0.0": ">=5.0.5 <6.0.0",
      "minimatch@^3.0.0": ">=3.1.4 <4.0.0",
      "minimatch@^5.0.0": ">=5.1.9 <6.0.0",
      "minimatch@^9.0.0": ">=9.0.9 <10.0.0",
      "minimatch@^10.0.0": ">=10.2.4 <11.0.0",
      "picomatch@^2.3.0": ">=2.3.2 <3.0.0",
      "picomatch@^3.0.0": ">=3.0.2 <4.0.0",
      "picomatch@^4.0.0": ">=4.0.4",
      "ajv@^6.0.0": ">=6.14.0 <7.0.0",
      "yaml@^2.0.0": ">=2.8.3 <3.0.0"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@9.9.0+sha512.60c18acd138bff695d339be6ad13f7e936eea6745660d4cc4a776d5247c540d0edee1a563695c183a66eb917ef88f2b4feb1fc25f32a7adcadc7aaf3438e99c1"
}
