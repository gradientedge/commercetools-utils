{
  "name": "@gradientedge/commercetools-utils",
  "version": "0.0.0-development",
  "description": "Provide utility classes and functions for interacting with the commercetools API",
  "main": "./dist/cjs/index.js",
  "module": "./dist/mjs/index.js",
  "types": "./dist/mjs/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/mjs/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/mjs/index.d.ts"
    }
  },
  "scripts": {
    "cz": "cz",
    "clean": "rimraf dist",
    "watch": "tsc --watch -p tsconfig.esm.json",
    "lint": "eslint './src/**/*.ts' --max-warnings=0",
    "generate-types": "node ./generate-type-exports.mjs",
    "package": "pnpm clean && pnpm build",
    "prepare": "husky",
    "prettier": "prettier --check \"**/*.{ts,js,json,graphql}\"",
    "prettify": "prettier --write \"**/*.{ts,js,json,graphql}\"",
    "validate": "npm run prettier && npm run lint && pnpm typecheck && pnpm build && npm run test",
    "docs": "typedoc --readme ./README.md",
    "semantic-release": "semantic-release",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.esm.json && pnpm build:commonjs",
    "build:commonjs": "tsc -p tsconfig-cjs.json",
    "build:watch": "tsc --watch -p tsconfig.esm.json",
    "test": "TZ=UTC vitest run",
    "test:coverage": "TZ=UTC vitest run --coverage",
    "prepack": "echo '{\"type\": \"commonjs\"}' > dist/cjs/package.json",
    "postpack": "rm -f dist/cjs/package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gradientedge/commercetools-utils.git"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "commercetools",
    "utils"
  ],
  "author": "Gradient Edge Ltd.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gradientedge/commercetools-utils/issues"
  },
  "homepage": "https://github.com/gradientedge/commercetools-utils#readme",
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@sinonjs/fake-timers": "15.3.2",
    "@types/json-stringify-safe": "5.0.3",
    "@types/node": "25.6.0",
    "@types/qs": "6.15.0",
    "@types/sinonjs__fake-timers": "15.0.1",
    "@types/traverse": "0.6.37",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "nock": "14.0.13",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "semantic-release": "25.0.3",
    "ts-node": "10.9.2",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@tshttp/status": "2.0.0",
    "axios": "1.15.2",
    "json-stringify-safe": "5.0.1",
    "qs": "6.15.1",
    "traverse": "0.6.11",
    "uuid": "14.0.0"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": "4.18.1",
      "lodash": "4.18.1"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
